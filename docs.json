{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hyperrail - Documentation",
  "appearance": {"default": "dark", "strict": true},
  "colors": {
    "primary": "#000000",
    "light": "#B5FD85",
    "dark": "#B5FD85"
  },
  "fonts": {
  "family": "IBM Plex Sans"
},
"styling": {"codeblocks": "dark"},
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Core Concepts",
            "pages": [
              {
                "group": "Getting Started",
                "icon": "rocket",
                "pages": [
                 "documentation/onboarding"
                ]
              },
               {
                "group": "KYB Verification",
                "icon": "id-card",
                "pages": [
                 "documentation/kyb-verification"
                ]
              }
            ]
          },
          {
            "group": "Features",
            "pages": [
              "documentation/features/offramp-transaction",
              "documentation/features/onramp-transaction",
              "documentation/features/currency-exchange-fiat",
              "documentation/features/team-members",
              "documentation/features/account-management"
            ]
          },
          {
            "group": "Expert Desk",
            "pages": [
              "documentation/support-channel/faq"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API Reference",
            "icon": "history",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/error-codes"

            ]
          },
          {
            "group": " ISO20022 Compliance",
            "icon": "wallet",
            "pages": [
              "api-reference/iso20022/endpoint-mapping"
            ]
          },
          {
            "group": "Wallets and Balances",
            "icon": "wallet",
            "pages": [
              "api-reference/hyperrail-wallet/get",
              "api-reference/hyperrail-wallet/get-balance-id",
              "api-reference/hyperrail-wallet/get-balance-currency"
            ]

          },
          {
            "group": "Exchange",
            "icon": "money-bill",
            "pages": [
              "api-reference/hyperrail-quote/create-express-quote",
              "api-reference/hyperrail-quote/create-payment-intent",
              "api-reference/hyperrail-quote/accept-quote",
              "api-reference/hyperrail-quote/get-quote-id",
              "api-reference/hyperrail-quote/get-complete-quote-id",
              "api-reference/hyperrail-quote/edit-quote",
              "api-reference/hyperrail-quote/cancel-quote",
              "api-reference/hyperrail-quote/delete-quote-item"
            ]
          },
          {
            "group": "Payout",
            "icon": "money-bill",
            "pages": [
              "api-reference/payout/withdrawal"
            ]
          },
          {
            "group": "Listings",
            "icon": "boxes",
            "pages": [
              "api-reference/listings/liquidity-providers"
            ]
          },
          {
            "group": "Dynamic Accounts",
            "icon": "vault",
            "pages": [
              "api-reference/dynamic-accounts/create-dynamic-account",
              "api-reference/dynamic-accounts/dynamic-account-id",
              "api-reference/dynamic-accounts/list-dynamic-account"
            ]
          }

        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/hyperrail-logo.svg",
    "dark": "/logo/hyperrail-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Get Started",
       "href": "https://app.hyperail.io/"
      }
    ]
  },
   "background": {
    "decoration": "grid",
    "color": {
      "light": "#ffffff",
       "dark": "#000"
    }
  },

  "redirects": [
    {
      "source": "/guides/login",
      "destination": "documentation/introduction"
    }
  
  ],
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  }
    

}
